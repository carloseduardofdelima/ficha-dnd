generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String           @default("USER")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  characters      Character[]
  savedCharacters SavedCharacter[]
  sessions        Session[]
  campaigns       Campaign[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Character {
  id               String           @id @default(cuid())
  slug             String           @unique
  userId           String
  name             String
  race             String           @default("")
  class            String           @default("")
  subclass         String?
  level            Int              @default(1)
  background       String?
  avatarUrl        String?
  strength         Int              @default(10)
  dexterity        Int              @default(10)
  constitution     Int              @default(10)
  intelligence     Int              @default(10)
  wisdom           Int              @default(10)
  charisma         Int              @default(10)
  maxHp            Int              @default(10)
  currentHp        Int              @default(10)
  armorClass       Int              @default(10)
  speed            Int              @default(30)
  initiative       Int              @default(0)
  proficiencyBonus Int              @default(2)
  skills           String?
  inventory        String?
  spells           String?
  traits           String?
  notes            String?
  isPublic         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  appearance       String?
  backstory        String?
  personalityTraits String?
  ideals           String?
  bonds            String?
  flaws            String?
  playerName       String?
  defenses         String?
  exp              String?
  subrace          String           @default("")
  resources        String?
  spellSlots       String?
  ruleset          String?          @default("2024")
  companions       String?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedBy          SavedCharacter[]
  campaigns        CharacterCampaignLink[]
}

model SavedCharacter {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  type        String   @default("campaign") // "one-shot" or "campaign"
  status      String   @default("active")   // "active", "paused", "finished"
  progress    Int      @default(0)
  coverUrl    String?
  system      String?
  averageLevel Int?
  startDate   DateTime?
  tags        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    CampaignSession[]
  notes_list  CampaignNote[]
  sharedLinks CampaignSharedLink[]
  combats     CampaignCombatSession[]
  monsters    Monster[]
  entities    Entity[]
  characters  CharacterCampaignLink[]
}

model CampaignSession {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  number      Int
  date        DateTime?
  summary     String?
  objectives  String?
  events      String?
  notes       String?
  status      String   @default("planned") // "planned", "in-progress", "completed"
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignNote {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  content     String
  isPublic    Boolean  @default(false)
  isFixed     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignSharedLink {
  id          String   @id @default(cuid())
  campaignId  String
  token       String   @unique
  permissions String?
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignCombatSession {
  id          String   @id @default(cuid())
  campaignId  String
  name        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participants CombatParticipant[]
}

model Entity {
  id          String   @id @default(cuid())
  campaignId  String?
  ownerId     String
  name        String
  type        String?
  description String?
  attributes  String?
  hp          Int?
  actions     String?
  flags       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign? @relation(fields: [campaignId], references: [id])
}

model Monster {
  id          String   @id @default(cuid())
  campaignId  String?
  ownerId     String
  name        String
  type        String?
  description String?
  attributes  String?
  hp          Int?
  ac          Int?
  resistances String?
  immunities  String?
  actions     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign? @relation(fields: [campaignId], references: [id])
}

model CharacterCampaignLink {
  id          String   @id @default(cuid())
  campaignId  String
  characterId String
  createdAt   DateTime @default(now())

  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([campaignId, characterId])
}

model CombatParticipant {
  id              String   @id @default(cuid())
  combatSessionId String
  entityId        String?
  characterId     String?
  initiative      Int      @default(0)
  hpCurrent       Int?
  conditions      String?
  createdAt       DateTime @default(now())

  combatSession   CampaignCombatSession @relation(fields: [combatSessionId], references: [id], onDelete: Cascade)
}
