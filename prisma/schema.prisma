generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String           @default("USER")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  characters      Character[]
  savedCharacters SavedCharacter[]
  sessions        Session[]
  campaigns       Campaign[]
  threats         Threat[]
  npcs            Npc[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Character {
  id               String           @id @default(cuid())
  slug             String           @unique
  userId           String
  name             String
  race             String           @default("")
  class            String           @default("")
  subclass         String?
  level            Int              @default(1)
  background       String?
  avatarUrl        String?
  strength         Int              @default(10)
  dexterity        Int              @default(10)
  constitution     Int              @default(10)
  intelligence     Int              @default(10)
  wisdom           Int              @default(10)
  charisma         Int              @default(10)
  maxHp            Int              @default(10)
  currentHp        Int              @default(10)
  armorClass       Int              @default(10)
  speed            Int              @default(30)
  initiative       Int              @default(0)
  proficiencyBonus Int              @default(2)
  skills           String?
  inventory        String?
  spells           String?
  traits           String?
  notes            String?
  isPublic         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  appearance       String?
  backstory        String?
  personalityTraits String?
  ideals           String?
  bonds            String?
  flaws            String?
  playerName       String?
  defenses         String?
  exp              String?
  subrace          String           @default("")
  resources        String?
  spellSlots       String?
  ruleset          String?          @default("2024")
  companions       String?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedBy          SavedCharacter[]
  campaigns        CharacterCampaignLink[]
}

model SavedCharacter {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  type        String   @default("campaign") // "one-shot" or "campaign"
  status      String   @default("active")   // "active", "paused", "finished"
  progress    Int      @default(0)
  coverUrl    String?
  system      String?
  averageLevel Int?
  startDate   DateTime?
  tags        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    CampaignSession[]
  notes_list  CampaignNote[]
  sharedLinks CampaignSharedLink[]
  combats     CampaignCombatSession[]
  threats     Threat[]
  npcs        Npc[]
  characters  CharacterCampaignLink[]
}

model CampaignSession {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  number      Int
  date        DateTime?
  summary     String?
  objectives  String?
  events      String?
  notes       String?
  status      String   @default("planned") // "planned", "in-progress", "completed"
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  npcs        SessionNpc[]
}

model CampaignNote {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  content     String
  isPublic    Boolean  @default(false)
  isFixed     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignSharedLink {
  id          String   @id @default(cuid())
  campaignId  String
  token       String   @unique
  permissions String?
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignCombatSession {
  id          String   @id @default(cuid())
  campaignId  String
  name        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participants CombatParticipant[]
}

model Threat {
  id              String           @id @default(cuid())
  userId          String
  campaignId      String?
  name            String
  description     String?
  threatType      String           @default("monster") // "monster", "npc", "boss", "entity", "custom"
  level           Int?
  challengeRating Float?
  isTemplate      Boolean          @default(false)
  isPublic        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  attributes      ThreatAttribute?
  combat          ThreatCombat?
  skills          ThreatSkill[]
  actions         ThreatAction[]
  instances       CombatInstance[]
}

model ThreatAttribute {
  id              String   @id @default(cuid())
  threatId        String   @unique
  strength        Int      @default(10)
  dexterity       Int      @default(10)
  constitution    Int      @default(10)
  intelligence    Int      @default(10)
  wisdom          Int      @default(10)
  charisma        Int      @default(10)
  hp              Int      @default(10)
  ac              Int      @default(10)
  speed           String?  @default("30ft")
  initiativeBonus Int      @default(0)

  threat          Threat   @relation(fields: [threatId], references: [id], onDelete: Cascade)
}

model ThreatCombat {
  id              String   @id @default(cuid())
  threatId        String   @unique
  attackBonus     Int      @default(0)
  damage          String?
  damageType      String?
  multiattack     String?
  abilities       String?  // JSON string
  resistances     String?  // Comma separated or JSON
  immunities      String?  // Comma separated or JSON
  vulnerabilities String? // Comma separated or JSON

  threat          Threat   @relation(fields: [threatId], references: [id], onDelete: Cascade)
}

model ThreatSkill {
  id          String   @id @default(cuid())
  threatId    String
  name        String
  description String
  cooldown    Int?

  threat      Threat   @relation(fields: [threatId], references: [id], onDelete: Cascade)
}

model ThreatAction {
  id          String   @id @default(cuid())
  threatId    String
  name        String
  description String
  actionType  String   @default("action") // "action", "bonus_action", "reaction", "passive"

  threat      Threat   @relation(fields: [threatId], references: [id], onDelete: Cascade)
}

model CombatInstance {
  id            String   @id @default(cuid())
  threatId      String
  currentHp     Int
  initiative    Int      @default(0)
  statusEffects String?  // JSON string
  customName    String?

  threat        Threat   @relation(fields: [threatId], references: [id], onDelete: Cascade)
}

model CharacterCampaignLink {
  id          String   @id @default(cuid())
  campaignId  String
  characterId String
  createdAt   DateTime @default(now())

  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([campaignId, characterId])
}

model CombatParticipant {
  id              String   @id @default(cuid())
  combatSessionId String
  threatId        String?
  characterId     String?
  initiative      Int      @default(0)
  hpCurrent       Int?
  conditions      String?
  createdAt       DateTime @default(now())

  combatSession   CampaignCombatSession @relation(fields: [combatSessionId], references: [id], onDelete: Cascade)
}

model Npc {
  id           String   @id @default(cuid())
  userId       String
  campaignId   String
  name         String
  title        String?
  avatarUrl    String?
  type         String   @default("neutro") // "aliado", "neutro", "inimigo", "comerciante", "quest_giver", "boss"
  description  String?
  notes        String?
  secrets      String?
  personality  String?
  appearance   String?
  status       String   @default("vivo") // "vivo", "morto", "desaparecido"
  tags         String?  // Store as comma separated string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sessions     SessionNpc[]
  combat       NpcCombat?
}

model SessionNpc {
  id         String   @id @default(cuid())
  sessionId  String
  npcId      String
  role       String? // ex: ajudou, atacou, apareceu
  createdAt  DateTime @default(now())

  npc        Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  session    CampaignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model NpcCombat {
  id           String   @id @default(cuid())
  npcId        String   @unique
  hp           Int      @default(10)
  ac           Int      @default(10)
  attackBonus  Int      @default(0)
  damage       String?
  notes        String?

  npc          Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)
}
